    "privacy-sec2-strong": "We do not collect personal data.",
    "privacy-sec2-desc": "WeatherAI works primarily on the client side.",
    "privacy-geo-title": "Geolocation:",
    "privacy-geo-desc": "Used only to retrieve weather data for your current location. Coordinates are sent to the Open-Meteo API but are not stored on our servers.",
    "privacy-local-title": "Local Storage:",
    "privacy-local-desc": "We use your browser's LocalStorage to save your settings (theme, language) and city search history. This data is stored only on your device.",
